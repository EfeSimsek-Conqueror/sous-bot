# ─────────────────────────────────────────────────────────────
# Sousbot environment — copy to apps/web/.env.local (web) and set
# the Edge Function secrets via `supabase secrets set` (backend).
# NEVER commit real values. All *.env / .env.local are gitignored.
# ─────────────────────────────────────────────────────────────

# ── Web (apps/web) — all public, safe to ship in the client bundle ──
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL=https://<project-ref>.functions.supabase.co

# ── Supabase Edge Function secrets (server-side only — set with
#    `supabase secrets set KEY=value --project-ref <project-ref>`) ──
FAL_KEY=<fal-key>                          # "id:secret" format
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
CORS_EXTRA_ORIGINS=https://your-deployment.example.com
STRIPE_WEBHOOK_SECRET=<stripe-webhook-signing-secret>       # optional until billing is wired
REVENUECAT_WEBHOOK_AUTH_TOKEN=<revenuecat-webhook-token>    # optional until billing is wired
# SUPABASE_URL / SUPABASE_ANON_KEY are injected automatically into Edge Functions.

# ── CLI / management (local dev only — treat like a root password) ──
SUPABASE_ACCESS_TOKEN=<your-supabase-access-token>
